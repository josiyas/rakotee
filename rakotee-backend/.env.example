PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/rakotee?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_strong_secret
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM="RAKOTEE <no-reply@yourdomain.com>"
EMAIL_SECURE=false
CLIENT_URL=http://localhost:5500

# Optional
TRUST_PROXY=false
FORCE_HTTPS=false
CORS_ALLOWED_ORIGINS=http://localhost:5500
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=false

# PayFast credentials - DO NOT COMMIT your real credentials. Set these in your deployment environment.
PAYFAST_MERCHANT_ID=your_payfast_merchant_id_here
PAYFAST_MERCHANT_KEY=your_payfast_merchant_key_here
PAYFAST_PASSPHRASE=optional_passphrase_from_payfast
PAYFAST_MODE=sandbox
# Set to true only if your platform/proxy forwards the real client IP correctly.
PAYFAST_ENFORCE_IP_CHECK=false
# Public backend URL used for PayFast notify_url (ITN), e.g. https://your-backend.onrender.com
SERVER_PUBLIC_URL=http://localhost:5000

# PayPal settings
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here
PAYPAL_MODE=sandbox # or live
PAYPAL_WEBHOOK_ID=your_webhook_id_from_paypal
